# Claude API (для умного извлечения данных)
ANTHROPIC_API_KEY=sk-ant-...

# Прокси (опционально, формат: http://user:pass@host:port)
# Можно перечислить несколько через запятую
PROXY_LIST=

# Настройки сервера
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Таймауты (секунды)
DEFAULT_TIMEOUT=30
PLAYWRIGHT_TIMEOUT=60

# Лимиты
MAX_CONCURRENT_TASKS=5
MAX_RETRIES=3
